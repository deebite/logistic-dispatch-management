<configuration>

    <springProperty scope="context" name="SERVICE_NAME" source="spring.application.name"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>[%-5level] | %d{yyyy-MM-dd HH:mm:ss.SSS} | [%t] | %c{1} | service=%property{SERVICE_NAME} | user=%X{username} | traceId=%X{traceId} | method=%X{method} | %msg%n
            </pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>